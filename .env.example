# EmpowerTours Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# BLOCKCHAIN CONFIGURATION
# =============================================================================

# Monad Testnet RPC
NEXT_PUBLIC_MONAD_RPC=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_CHAIN_ID=10143

# =============================================================================
# ERC-4337 ACCOUNT ABSTRACTION (BUNDLERS)
# =============================================================================

## Pimlico (Current Primary Bundler - Battle-tested)
NEXT_PUBLIC_PIMLICO_API_KEY=your_pimlico_api_key_here
NEXT_PUBLIC_PIMLICO_BUNDLER_URL=https://api.pimlico.io/v2/monad-testnet/rpc

## FastLane (Monad-Optimized Bundler - Testing Alongside Pimlico)
NEXT_PUBLIC_FASTLANE_BUNDLER_URL=https://monad-testnet.4337-shbundler-fra.fastlane-labs.xyz
NEXT_PUBLIC_FASTLANE_ENABLED=false  # Set to 'true' to enable A/B testing (10% traffic)

## Shared ERC-4337 Configuration
NEXT_PUBLIC_ENTRYPOINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032

# =============================================================================
# FASTLANE CONTRACTS (shMON Liquid Staking)
# =============================================================================

# shMON Liquid Staking Contract (✅ DEPLOYED on Monad Testnet)
NEXT_PUBLIC_SHMON_ADDRESS=0x3a98250F98Dd388C211206983453837C8365BDc1

# =============================================================================
# SAFE ACCOUNT
# =============================================================================

# Platform Safe (for delegated transactions)
NEXT_PUBLIC_SAFE_ACCOUNT=your_safe_account_address

# =============================================================================
# DEPLOYED CONTRACTS (Monad Testnet)
# =============================================================================

# Core Tokens
NEXT_PUBLIC_TOURS_TOKEN=0xa123600c82E69cB311B0e068B06Bfa9F787699B7
NEXT_PUBLIC_WMON=0x760AfE86e5de5fa0Ee542fc7B7B713e1c5425701

# NFT Contracts
NEXT_PUBLIC_PASSPORT=0x820A9cc395D4349e19dB18BAc5Be7b3C71ac5163
NEXT_PUBLIC_NFT_CONTRACT=  # EmpowerToursNFTv10 (Music + Art with DAO Timelock)
NEXT_PUBLIC_PASSPORT_NFT_V2=
NEXT_PUBLIC_EXPERIENCE_NFT=  # New GPS-revealed experiences contract

# Game Contracts
NEXT_PUBLIC_MUSIC_BEAT_MATCH=
NEXT_PUBLIC_COUNTRY_COLLECTOR=

# DeFi Contracts
NEXT_PUBLIC_YIELD_STRATEGY=0x37aC86916Ae673bDFCc9c712057092E57b270f5f
NEXT_PUBLIC_TANDA_POOL=

# DEX
NEXT_PUBLIC_TOURS_WMON_POOL=
NEXT_PUBLIC_DRAGON_ROUTER=0x00EA77CfCD29d461250B85D3569D0E235d8Fbd1e

# Service Contracts
NEXT_PUBLIC_SERVICE_MARKETPLACE=
NEXT_PUBLIC_ITINERARY_NFT=  # Legacy (being replaced by ExperienceNFT)

# =============================================================================
# EXTERNAL APIS
# =============================================================================

# Neynar (Farcaster API)
NEXT_PUBLIC_NEYNAR_API_KEY=your_neynar_api_key
NEYNAR_API_KEY=your_neynar_api_key  # Server-side

# Pinata (IPFS Storage)
NEXT_PUBLIC_PINATA_API_KEY=your_pinata_api_key
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# Envio Indexer (GraphQL)
NEXT_PUBLIC_ENVIO_ENDPOINT=your_envio_graphql_endpoint

# Privy (Auth)
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id

# Gemini AI (for daily challenges)
GEMINI_API_KEY=your_gemini_api_key

# =============================================================================
# APP CONFIGURATION
# =============================================================================

# App URL (for webhooks and redirects)
NEXT_PUBLIC_URL=https://fcempowertours-production.up.railway.app

# =============================================================================
# NOTES
# =============================================================================

# Bundler Strategy (Hybrid Approach):
# - Keep PIMLICO as primary (working, battle-tested)
# - Test FASTLANE in parallel (Monad-optimized, validator-integrated)
# - Enable A/B testing with NEXT_PUBLIC_FASTLANE_ENABLED=true
# - See PIMLICO_FASTLANE_HYBRID.md for architecture details

# shMON Integration:
# - Liquid staking for savings, escrow, treasury
# - Earn 5% APY on all idle MON
# - Pay gas fees from staking yield (sustainable!)
# - See SHMONAD_INTEGRATION.md for use cases

# Testnet vs Mainnet:
# - Current: Monad Testnet (chain ID 10143)
# - Mainnet: Coming soon (see MAINNET_DEPLOYMENT_GUIDE.md)
