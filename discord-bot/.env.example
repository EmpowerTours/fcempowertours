# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_GUILD_ID=your_discord_server_id

# Blockchain Configuration
NETWORK=testnet
# testnet or mainnet

# Monad RPC URLs
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz
MONAD_MAINNET_RPC=https://rpc.monad.xyz

# TOURS Token Contract Address
TOURS_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# Tip Pool Wallet (private key for bot to send tips)
# WARNING: Keep this secure! Only use a dedicated wallet for tips
TIP_POOL_PRIVATE_KEY=0x...

# Claim Contract Address (optional, for airdrops)
CLAIM_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=tours:

# Farcaster / Neynar API
NEYNAR_API_KEY=your_neynar_api_key

# Role IDs for Token-Gated Roles
# Create roles in your Discord server and copy their IDs
ROLE_BRONZE_ID=
ROLE_SILVER_ID=
ROLE_GOLD_ID=

# Role Tiers (minimum TOURS balance for each tier)
# Default: Bronze = 1,000 TOURS, Silver = 10,000 TOURS, Gold = 100,000 TOURS
