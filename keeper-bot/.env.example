# Network Configuration
RPC_URL=https://testnet-rpc.monad.xyz
CHAIN_ID=10143

# Contract Addresses
MUSIC_BEAT_MATCH=0xee83AC7E916f4feBDb7297363B47eE370FE2EC87
COUNTRY_COLLECTOR=0xb7F929B78F2A88d97CdC9Ef0235b113dd8351200
TOURS_TOKEN=0xa123600c82E69cB311B0e068B06Bfa9F787699B7

# Authentication (Platform Safe keeper account)
PLATFORM_SAFE_KEY=your_private_key_here

# Data Sources
ENVIO_ENDPOINT=https://indexer.bigdevenergy.link/5e18e81/v1/graphql

# IPFS (Pinata)
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key

# Scheduling (cron expressions)
# Music Beat Match: Daily at midnight UTC
BEAT_MATCH_CRON="0 0 * * *"
# Country Collector: Weekly on Sunday midnight UTC
COLLECTOR_CRON="0 0 * * 0"
# Finalize: Every hour
FINALIZE_CRON="0 * * * *"

# Monitoring (optional)
ALERT_WEBHOOK=your_discord_or_slack_webhook_url
HEALTH_CHECK_PORT=3001

# Logging
LOG_LEVEL=info
